@using web.holidaydo.mvc.Controllers
@model List<All_destinationsController.RegionWithCountries>

@{
    ViewData["Title"] = "All Destinations";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">All Destinations</li>
        </ol>
    </nav>

    <!-- Page Title -->
    <h1 class="mb-5 fw-bold">All Destinations</h1>

    @if (Model != null && Model.Any())
    {
        @foreach (var region in Model)
        {
            <section class="mb-5">
                <h2 class="h4 fw-bold text-dark mb-4">@region.Title</h2>
                @if (region.Countries.Any())
                {
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="destination-list">
                                @foreach (var country in region.Countries.Take((region.Countries.Count + 1) / 2))
                                {
                                    <li><a href="/destination/@country.Slug/@country.Id">@country.Name</a></li>
                                }
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="destination-list">
                                @foreach (var country in region.Countries.Skip((region.Countries.Count + 1) / 2))
                                {
                                    <li><a href="/destination/@country.Slug/@country.Id">@country.Name</a></li>
                                }
                            </ul>
                        </div>
                    </div>
                }
                <hr class="my-4">
            </section>
        }
    }
    else
    {
        <p class="text-muted">No destinations available.</p>
    }
</div>

<style>
    .breadcrumb-item a {
        color: darkblue;
    }

    .destination-list {
        list-style: none;
        padding: 0;
    }

    .destination-list li {
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
    }

    .destination-list li::before {
        content: "•";
        color: #f39c12;
        font-size: 1.5rem;
        margin-right: 0.75rem;
        line-height: 1;
    }

    .destination-list a {
        text-decoration: none;
        color: darkblue;
        font-size: 1.1rem;
        transition: color 0.2s ease;
    }

    .destination-list a:hover {
        color: #0a8ba8;
    }

    h2 {
        border-bottom: 1px solid #e9ecef;
        padding-bottom: 1rem;
    }
</style>
