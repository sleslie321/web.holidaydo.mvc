@model web.holidaydo.mvc.Controllers.HomeController.HomeIndexViewModel

<section id="search" class="search-section">
    <div class="container">
        <div class="search-card search-card--split position-relative overflow-visible">
            <div class="row g-0 align-items-stretch">
                <div class="col-lg-6 d-none d-lg-block">
                    <div class="search-card-media">
                        <img src="/img/search/search.png"
                             alt="Holiday travellers"
                             class="search-card-image" />
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="search-card-content">
                        <h2 class="search-card-title mb-3">
                            Find your next place to explore
                        </h2>

                        <p class="search-card-subtitle mb-4">
                            Search cities, counties, and destinations to jump straight to the best activities and deals.
                        </p>

                        <div class="search-autocomplete position-relative">
                            <label for="destination-search" class="form-label fw-semibold search-label">Destination</label>

                            <div class="input-group input-group-lg search-input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="bi bi-geo-alt"></i>
                                </span>

                                <input id="destination-search"
                                       type="text"
                                       class="form-control border-start-0"
                                       placeholder="Where do you want to go?"
                                       autocomplete="off" />
                            </div>

                            <div id="destination-suggestions"
                                 class="list-group position-absolute w-100 search-autocomplete-menu d-none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="topdestinations" class="py-4" style="background:#f3f3f3;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4 mb-0 fw-semibold">Popular Destinations</h2>
            <a href="#" class="text-dark text-decoration-underline small">View All Destinations</a>
        </div>

        <div class="row g-4">
            @if (Model.PopularDestinations.Count > 0)
            {
                foreach (var tdest in Model.PopularDestinations)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="/destination/@tdest.Slug/@tdest.Id" class="text-decoration-none text-dark">
                            <div class="destination-item d-flex align-items-center">
                                <img src="/images/popular/@(tdest.Slug).jpg" alt="@tdest.Title" class="rounded-circle flex-shrink-0">
                                <div class="ms-3">
                                    <h3 class="h6 mb-1">@tdest.Title</h3>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

<section class="home-welcome position-relative overflow-hidden">
    <div class="home-welcome-overlay"></div>

    <div class="container position-relative">
        <div class="row align-items-center min-vh-50 py-5 py-lg-6">
            <div class="col-lg-5 text-white text-center text-lg-start home-welcome-copy">
                <h1 class="display-4 fw-semibold mb-3">
                    Do More on Holiday.
                </h1>

                <p class="mb-4 text-white-50">
                    Discover tours, boat trips, water parks, family days out, city experiences,
                    and hidden gems tailored to your next holiday.
                </p>

                <a href="#destinations" class="btn btn-warning btn-lg px-4 fw-semibold">
                    Explore More
                </a>
            </div>

            <div class="col-lg-7 position-relative text-center mt-0">
                <img src="img/home/people.png"
                     alt="Travellers planning their next holiday"
                     class="img-fluid home-welcome-people" />
            </div>
        </div>
    </div>
</section>

<section id="explore-world" class="explore-world-section py-5">
    <div class="container">
        <h2 class="explore-world-title text-center mb-4 mb-lg-5">EXPLORE THE WORLD</h2>

        <div class="row justify-content-center g-4 g-lg-5">
            <div class="col-6 col-sm-4 col-md-4 col-lg-2 text-center">
                <a href="/region/europe/6" class="world-region-link  d-inline-block text-decoration-none">
                    <span class="world-region-circle">
                        <img src="/img/home/europe.png" alt="Europe" class="world-region-image" />
                    </span>
                    <span class="world-region-name">EUROPE</span>
                </a>
            </div>

            <div class="col-6 col-sm-4 col-md-4 col-lg-2 text-center">
                <a href="/region/africa/1" class="world-region-link d-inline-block text-decoration-none">
                    <span class="world-region-circle">
                        <img src="/img/home/africa.png" alt="Africa" class="world-region-image" />
                    </span>
                    <span class="world-region-name">AFRICA</span>
                </a>
            </div>

            <div class="col-6 col-sm-4 col-md-4 col-lg-2 text-center">
                <a href="/region/america/8" class="world-region-link d-inline-block text-decoration-none">
                    <span class="world-region-circle">
                        <img src="/img/home/america.png" alt="America" class="world-region-image" />
                    </span>
                    <span class="world-region-name">AMERICA</span>
                </a>
            </div>

            <div class="col-6 col-sm-4 col-md-4 col-lg-2 text-center">
                <a href="/region/south-america/9" class="world-region-link d-inline-block text-decoration-none">
                    <span class="world-region-circle">
                        <img src="/img/home/south-a.png" alt="South America" class="world-region-image" />
                    </span>
                    <span class="world-region-name">SOUTH-AMERICA</span>
                </a>
            </div>

            <div class="col-6 col-sm-4 col-md-4 col-lg-2 text-center">
                <a href="/region/australia/3" class="world-region-link d-inline-block text-decoration-none">
                    <span class="world-region-circle">
                        <img src="/img/home/australia.png" alt="Australia" class="world-region-image" />
                    </span>
                    <span class="world-region-name">AUSTRALIA</span>
                </a>
            </div>

            <div class="col-6 col-sm-4 col-md-4 col-lg-2 text-center">
                <a href="/region/asia/2" class="world-region-link d-inline-block text-decoration-none">
                    <span class="world-region-circle">
                        <img src="/img/home/asia.png" alt="Asia" class="world-region-image" />
                    </span>
                    <span class="world-region-name">ASIA</span>
                </a>
            </div>
        </div>
    </div>
</section>


<section class="top-lists-section py-5 py-lg-6">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="top-list-block">
                    <h2 class="top-list-heading">Top countries</h2>
                    <ul class="list-inline top-link-list mb-0">
                        @foreach (var item in Model.TopCountries)
{
    <li class="list-inline-item top-link-item">
        <a href="@($"/destination/{Uri.EscapeDataString(item.Slug)}/{item.Id}")" class="top-link">@item.Title</a>
    </li>
}
                    </ul>
                </div>

                <div class="top-list-block">
                    <h2 class="top-list-heading">Top destinations</h2>
                    <ul class="list-inline top-link-list mb-0">
                        @foreach (var item in Model.TopDestinations)
{
    <li class="list-inline-item top-link-item">
        <a href="@($"/destination/{Uri.EscapeDataString(item.Slug)}/{item.Id}")" class="top-link">@item.Title</a>
    </li>
}
                    </ul>
                </div>

                
            </div>
        </div>
    </div>
</section>


<script>
    (() => {
        const input = document.getElementById("destination-search");
        const suggestions = document.getElementById("destination-suggestions");
        let abortController = null;

        function hideSuggestions() {
            suggestions.classList.add("d-none");
            suggestions.innerHTML = "";
        }

        function renderSuggestions(items) {
            if (!items || items.length === 0) {
                hideSuggestions();
                return;
            }

            suggestions.innerHTML = "";

            for (const item of items) {
                const button = document.createElement("button");
                button.type = "button";
                button.className = "list-group-item list-group-item-action d-flex justify-content-between align-items-center";

                const name = document.createElement("span");
                name.textContent = item.name ?? "";

                const type = document.createElement("small");
                type.className = "text-secondary";
                type.textContent = item.type ?? "";

                button.appendChild(name);
                button.appendChild(type);

                button.addEventListener("click", () => {
                    input.value = item.name ?? "";
                    hideSuggestions();

                    if (item.slug && item.id) {
                        window.location.href = `/destination/${item.slug}/${item.id}`;
                    }
                });

                suggestions.appendChild(button);
            }

            suggestions.classList.remove("d-none");
        }

        async function loadSuggestions(query) {
            if (abortController) {
                abortController.abort();
            }

            abortController = new AbortController();

            try {
                const response = await fetch(`/Home/Autocomplete?q=${encodeURIComponent(query)}&take=10`, {
                    signal: abortController.signal
                });

                if (!response.ok) {
                    hideSuggestions();
                    return;
                }

                const items = await response.json();
                renderSuggestions(items);
            } catch (error) {
                if (error.name !== "AbortError") {
                    hideSuggestions();
                }
            }
        }

        input.addEventListener("input", async (e) => {
            const query = e.target.value.trim();

            if (query.length < 2) {
                hideSuggestions();
                return;
            }

            await loadSuggestions(query);
        });

        document.addEventListener("click", (e) => {
            if (!input.contains(e.target) && !suggestions.contains(e.target)) {
                hideSuggestions();
            }
        });
    })();
</script>
