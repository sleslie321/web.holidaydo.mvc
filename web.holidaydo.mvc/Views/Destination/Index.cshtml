@using System.Net
@using web.holidaydo.mvc.Controllers
@using web.holidaydo.mvc.Models
@model DestinationController.DestinationViewModel
@{
    var destination = Model;
    var breadcrumbs = string.IsNullOrWhiteSpace(destination?.BreadCrumbJson)
        ? new List<System.Text.Json.JsonElement>()
        : System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(destination.BreadCrumbJson) ?? new List<System.Text.Json.JsonElement>();
}



@if (destination is null)
{
    <div class="destination-loading text-center py-5">
        <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
        <div class="mt-3 text-muted">Loading destination...</div>
    </div>
}
else
{
    

    <section class="portfolio-header mb-4"
             style="background-image: linear-gradient(rgba(8,18,32,.62), rgba(8,18,32,.62)), url('/img/destination/header.jpg');">
        <div class="container">
            <div class="row align-items-center portfolio-header-inner">
                <div class="col-md-8">
                    <h1 class="portfolio-title mb-0">
                        @destination.Title
                    </h1>
                    <p class="portfolio-description">@destination.Description</p>
                </div>
                <div class="col-md-4" style="text-align:right !important">
                    <h3 style="color:white">Do More on Holiday!</h3>
                </div>
            </div>
        </div>
    </section>

    <div class="container mb-3">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-lg-between gap-2">

            @if (breadcrumbs.Any())
            {
                <nav aria-label="breadcrumb" class="mb-0 flex-grow-1">
                    <ol class="breadcrumb mb-0 px-3 py-2 bg-body-tertiary border rounded">
                        <li class="breadcrumb-item">
                            <a href="/" aria-label="Home">
                                <i class="bi bi-house-fill"></i>
                                <span class="visually-hidden">Home</span>
                            </a>
                        </li>

                        @for (var i = 0; i < breadcrumbs.Count; i++)
                        {
                            var crumb = breadcrumbs[i];
                            var isLast = i == breadcrumbs.Count - 1;
                            var crumbSlug = crumb.TryGetProperty("slug", out var slugProperty)
                                ? slugProperty.GetString() ?? string.Empty
                                : string.Empty;
                            var crumbDestinationId = crumb.TryGetProperty("destinationId", out var destinationIdProperty) && destinationIdProperty.TryGetInt32(out var destinationId)
                                ? destinationId
                                : 0;
                            var crumbName = crumb.TryGetProperty("name", out var nameProperty)
                                ? nameProperty.GetString() ?? string.Empty
                                : string.Empty;
                            var href = i == 0
                                ? $"/region/{crumbSlug}/{crumbDestinationId}"
                                : $"/destination/{crumbSlug}/{crumbDestinationId}";

                            if (isLast)
                            {
                                <li class="breadcrumb-item active" aria-current="page">@crumbName</li>
                            }
                            else
                            {
                                <li class="breadcrumb-item">
                                    <a href="@href">@crumbName</a>
                                </li>
                            }
                        }
                    </ol>
                </nav>
            }

           
        </div>
    </div>

    @if (destination.SearchProducts?.Products.Any() == true)
    {
        <section id="destination-widget" class="py-1 bg-hd-light">
            <div class="container py-4">

                

                <div class="row g-4">
                    @foreach (Product product in destination.SearchProducts.Products)
                    {
                        <div class="col-12 col-sm-6 col-lg-3">
                            <div class="tour-card border border-secondary-subtle">
                                <div class="image-wrap">
                                    @if (product.Flags != null && product.Flags.Contains("LIKELY_TO_SELL_OUT"))
                                    {
                                        <span class="special-offer">Likely to sell out</span>
                                    }
                                    <img src="@product.Images?.FirstOrDefault()?.Variants?[1].Url" alt="@product.Title">
                                </div>

                                <div class="pt-2 tour-card-body">
                                    <div class="rating-line">
                                        Average rating: @DestinationController.FormatRating(product.Reviews?.CombinedAverageRating)
                                        <i class="bi bi-star-fill star"></i>
                                        from @product.Reviews?.TotalReviews reviews
                                    </div>

                                    <div class="tour-title">
                                        <a href="@product.ProductUrl" target="_blank" title="@product.Title">
                                            @product.Title
                                        </a>
                                    </div>

                                    @if (product.Flags?.Any() == true)
                                    {
                                        @foreach (var flag in product.Flags)
                                        {
                                            <div class="meta-line">
                                                <i class="bi bi-check-circle"></i>
                                                <div class="flags-list">
                                                    <span class="flag-item">@DestinationController.FormatFlag(flag)</span>
                                                </div>
                                            </div>
                                        }
                                    }

                                    <div class="meta-line">
                                        <i class="bi bi-clock"></i>
                                        @if (product.Duration?.FixedDurationInMinutes != null)
                                        {
                                            <span>@DestinationController.FormatDuration(product.Duration.FixedDurationInMinutes, true)</span>
                                        }
                                        @if (product.Duration?.VariableDurationFromMinutes != null)
                                        {
                                            <span>@DestinationController.FormatDuration(product.Duration?.VariableDurationFromMinutes, false) - @DestinationController.FormatDuration(product.Duration?.VariableDurationToMinutes, true)</span>
                                        }
                                    </div>

                                    <div class="price-line">
                                        <span class="from">from</span><span class="price-new">£@product.Pricing?.Summary?.FromPrice</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (destination.TotalPages > 1)
                    {
                        <div class="d-flex justify-content-center justify-content-md-end mb-3">
                            <nav aria-label="Destination products pages">
                                <ul class="pagination mb-0">
                                    <li class="page-item @(destination.CurrentPage == 1 ? "disabled" : "")">
                                        @if (destination.CurrentPage == 1)
                                        {
                                            <span class="page-link">Previous</span>
                                        }
                                        else
                                        {
                                            <a class="page-link"
                                               href="@Url.Action("Index", "Destination", new { slug = destination.Slug, id = destination.Id, page = destination.CurrentPage - 1 })">Previous</a>
                                        }
                                    </li>

                                    @for (var p = 1; p <= destination.TotalPages; p++)
                                    {
                                        <li class="page-item @(p == destination.CurrentPage ? "active" : "")">
                                            <a class="page-link"
                                               href="@Url.Action("Index", "Destination", new { slug = destination.Slug, id = destination.Id, page = p })">@p</a>
                                        </li>
                                    }

                                    <li class="page-item @(destination.CurrentPage == destination.TotalPages ? "disabled" : "")">
                                        @if (destination.CurrentPage == destination.TotalPages)
                                        {
                                            <span class="page-link">Next</span>
                                        }
                                        else
                                        {
                                            <a class="page-link"
                                               href="@Url.Action("Index", "Destination", new { slug = destination.Slug, id = destination.Id, page = destination.CurrentPage + 1 })">Next</a>
                                        }
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>

            </div>
        </section>
       

    }

    @if (destination.Extra?.DealApiUrl != null && destination.Deals?.Any() == true)
    {
        <section id="topdeals" class="py-5 bg-white">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="text-uppercase fw-semibold d-inline-block border-bottom border-2 border-success pb-2 px-4">
                        Top deals in @destination.Title
                    </h2>
                    <p class="text-secondary mb-0 mt-2">Grab yourself a deal - changing daily!</p>
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-0 border-top border-start">
                    @foreach (var deal in destination.Deals!.Take(3))
                    {
                        var originalUrl = "https://www.wowcher.co.uk" + deal.UrlPath;
                        var affiliateUrl =
                            $"https://www.awin1.com/cread.php?awinmid=3595&awinaffid=5819&ued={WebUtility.UrlEncode(originalUrl)}";

                        <div class="col border-end border-bottom">
                            <article class="d-flex flex-column justify-content-between p-4 h-100">
                                <div>
                                    @if (deal.DiscountPercentageIncludingAdminFee is > 0)
                                    {
                                        <div class="small text-danger fw-semibold mb-2">
                                            Save up to @deal.DiscountPercentageIncludingAdminFee%
                                        </div>
                                    }

                                    <h3 class="h5 mb-3">
                                        <a href="@affiliateUrl" target="_blank" rel="noopener noreferrer">@deal.Headline</a>
                                    </h3>

                                    @if (!string.IsNullOrWhiteSpace(deal.Title))
                                    {
                                        <div class="small text-secondary mb-3">@deal.Title</div>
                                    }
                                </div>

                                @if (deal.Price.HasValue)
                                {
                                    <div class="d-flex align-items-center flex-wrap gap-2">
                                        <span class="fs-4 fw-bold text-success">£@deal.Price.Value.ToString("0.00")</span>
                                    </div>
                                }
                            </article>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    @if (destination.Extra?.GetId != null)
    {
        <section id="activities" class="py-2 bg-hd-light">
            <div class="container">
                <h2>Top activities in @destination.Title</h2>
                <div data-gyg-href="https://widget.getyourguide.com/default/activities.frame"
                     data-gyg-location-id="@destination.Extra.GetId"
                     data-gyg-locale-code="en-US"
                     data-gyg-widget="activities"
                     data-gyg-number-of-items="12"
                     data-gyg-partner-id="SSYAMZU"></div>
            </div>
        </section>
    }
    else
    {
        <section id="activities" class="py-2 bg-hd-light">
            <div class="container">
                <h2>Top activities in @destination.Title</h2>
                <div data-gyg-widget="auto" data-gyg-partner-id="SSYAMZU"></div>
            </div>
        </section>
    }

 

    <section id="destination-spotlight" class="destination-spotlight-section py-5 py-lg-6">
        <div class="container text-center">
            <h2 class="destination-spotlight-title mb-4">@destination.Title</h2>
            <p class="destination-spotlight-copy mb-0">
                @(destination.LongDescription ?? string.Empty)
            </p>
        </div>
    </section>

    @if (destination.Type == "COUNTRY" && destination.CountryCities.Any())
    {
        <section class="destination-info py-4">
            <div class="container">
                <h2>Explore @destination.Title further:</h2>
                <div class="city-scroll d-flex flex-wrap gap-3">
                    @foreach (var city in destination.CountryCities)
                    {
                        <a href="@Url.Action("Index", "Destination", new { slug = city.Slug, id = city.DestinationId })"
                           class="city-link">@city.Name</a>
                    }
                </div>
            </div>
        </section>



    }


    @if (destination.Books.Any())
    {
        <section id="books" class="py-5 bg-white">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="text-uppercase fw-semibold d-inline-block border-bottom border-2 border-success pb-2 px-4">
                        Travel books for @destination.Title
                    </h2>
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-0 border-top border-start">
                    @foreach (var book in destination.Books)
                    {
                        <div class="col border-end border-bottom">
                            <article class="d-flex gap-3 p-4 h-100">
                                @if (!string.IsNullOrWhiteSpace(book.ImageUrl))
                                {
                                    <img src="@book.ImageUrl"
                                         alt="@book.Title"
                                         class="img-fluid flex-shrink-0 shadow-sm"
                                         style="width:96px; height:140px; object-fit:cover;" />
                                }

                                <div class="d-flex flex-column justify-content-between min-w-0">
                                    <div>
                                        @if (!string.IsNullOrWhiteSpace(book.Author))
                                        {
                                            <div class="small text-secondary mb-2">@book.Author</div>
                                        }

                                        <h3 class="h5 mb-3">
                                            @if (!string.IsNullOrWhiteSpace(book.Url))
                                            {
                                                <a href="@book.Url" target="_blank" rel="noopener noreferrer">@book.Title</a>
                                            }
                                            else
                                            {
                                                @book.Title
                                            }
                                        </h3>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(book.PriceDisplay))
                                    {
                                        <div class="d-flex align-items-center flex-wrap gap-2">
                                            <span class="fs-4 fw-bold text-success">@book.PriceDisplay</span>
                                        </div>
                                    }
                                    else if (book.Price.HasValue)
                                    {
                                        <div class="d-flex align-items-center flex-wrap gap-2">
                                            <span class="fs-4 fw-bold text-success">£@book.Price.Value.ToString("0.00")</span>
                                        </div>
                                    }
                                </div>
                            </article>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}

